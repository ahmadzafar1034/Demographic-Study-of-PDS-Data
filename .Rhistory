library(knitr)
library(kableExtra)
library(dplyr)
# Consistent styled table helper
style_tbl <- function(df, caption = NULL, font_size = 15) {
kable(df, caption = caption, format = "html") %>%
kable_styling(
bootstrap_options = c("striped", "hover", "condensed"),
full_width = TRUE,
position = "center",
font_size = font_size) %>%
row_spec(0, bold = TRUE, background = "#34495e", color = "white")
}
key_indicators <- data.frame(
Indicator = c("Sex Ratio", "Total Population", "Crude Birth Rate",
"General Fertility Rate", "Total Fertility Rate",
"Infant Mortality Rate", "Early Marriage (before 22)",
"Child Marriage (before 18)"),
Value = c("102.57 M per 100F", "220.6 million", "26.88 per 1,000",
"111.80 per 1,000", "3.685 children", "55.75 per 1,000 births",
"40%", "20%"),
Assessment = c("Balanced", "Young structure", "High", "High",
"Above replacement", "High", "Widespread", "Significant")
)
style_tbl(key_indicators, font_size = 14)
pop_summary <- data.frame(
Metric = c("Survey Records", "Weighted Population", "Mean Age",
"Median Age", "Proportion Under 15"),
Value = c("225,900 individuals", "220,579,436", "34.2 years",
"31.8 years", "43%")
)
style_tbl(pop_summary, font_size = 13)
sex_ratio_data <- data.frame(
Category = c("Males (Weighted)", "Females (Weighted)", "Sex Ratio"),
Value = c("808,458,747", "788,180,040", "102.57 per 100 females"),
Assessment = c("National estimate", "National estimate",
"Within natural range of 98–105")
)
style_tbl(sex_ratio_data, font_size = 15)
fertility_rates <- data.frame(
Measure = c("Crude Birth Rate", "General Fertility Rate", "Total Fertility Rate"),
Value = c("26.88 per 1,000", "111.80 per 1,000 women (15–49)", "3.685 children per woman"),
Benchmark = c("Global avg: 18 per 1,000", "3–4x higher than developed nations",
"Replacement level: 2.1")
)
style_tbl(fertility_rates, font_size = 14)
asfr_summary <- data.frame(
`Age Group` = c("15-19", "20-24", "25-29", "30-34", "35-39", "40-44", "45-49"),
`ASFR (per 1,000)` = c("~85", "~175", "209.34", "~150", "~90", "~35", "~8"),
check.names = FALSE
)
style_tbl(asfr_summary, font_size = 13)
marriage_summary <- data.frame(
`Age Category` = c("Under 15", "15-17", "18-21", "22-24", "25-29", "30+"),
Percentage = c("0.03%", "29.4%", "36.0%", "21.3%", "10.8%", "2.4%"),
check.names = FALSE
)
style_tbl(marriage_summary, font_size = 14)
mortality_summary <- data.frame(
Indicator = c("Crude Death Rate", "Infant Mortality Rate (2018-2020)",
"Annual Infant Deaths"),
Value = c("6.67 per 1,000", "55.75 per 1,000 live births", "~331,000"),
Note = c("Low due to young age structure, not health outcomes",
"Unacceptably high by global standards",
"One infant death every 2.5 seconds")
)
style_tbl(mortality_summary, font_size = 14)
deaths_place <- data.frame(
Location = c("Home", "Hospital/Clinic", "On Road", "Other"),
Percentage = c("58.5%", "38.1%", "2.8%", "0.7%")
)
style_tbl(deaths_place, font_size = 13)
deaths_gender <- data.frame(
Location = c("Home", "Hospital", "On Road"),
`M:F Ratio` = c("1.03", "1.25", "2.42"),
check.names = FALSE
)
style_tbl(deaths_gender, font_size = 13)
q()
